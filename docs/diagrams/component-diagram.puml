@startuml diagrama-componentes
title Sistema de Moeda Estudantil — Diagrama de Componentes

skinparam componentStyle rectangle
skinparam defaultFontSize 10
skinparam nodeSep 40
skinparam rankSep 65
skinparam arrowColor #444444
skinparam componentBorderColor #777777
skinparam nodeBorderColor #555555
skinparam nodeBackgroundColor #F8F8F8
skinparam interfaceBackgroundColor #FFFDE7
skinparam interfaceBorderColor #AAAAAA

top to bottom direction

' ═══════════════════════════════════════════
'  CAMADA 1 — FRONTEND
' ═══════════════════════════════════════════
node "Frontend  (React + Vite + TypeScript)" as FE {
  component [Módulos de Funcionalidade\nauth | aluno | professor | empresa | vantagens | extrato] as Modulos
  component [Contexto de Autenticação] as AuthCtx
  component [Componentes UI Compartilhados] as UIShared
  component [Cliente HTTP (axios)] as HTTPCliente

  Modulos --> AuthCtx
  Modulos --> HTTPCliente
  Modulos ..> UIShared : usa
}

' ── Interface: HTTP Layer fornece, Frontend requer ──
() "IRestAPI" as IRestAPI

' ═══════════════════════════════════════════
'  CAMADA 2 — CONTROLADORES
' ═══════════════════════════════════════════
node "Camada HTTP  (Node.js + Express)" as HTTP_Layer {
  component [Middleware JWT] as MidJWT
  component [Middleware Validação\n(zod)] as MidVal
  component [ControladorAuth] as CAuth
  component [ControladorAluno] as CAluno
  component [ControladorProfessor] as CProf
  component [ControladorEmpresa] as CEmpresa
  component [ControladorVantagem] as CVant

  MidJWT --> CAluno
  MidJWT --> CProf
  MidVal --> CAuth
  MidVal --> CAluno
}

' ── Interfaces: Serviços fornecem, Controladores requerem ──
() "IServicoAuth" as ISvcAuth
() "IServicoMoeda" as ISvcMoeda
() "IServicoVantagem" as ISvcVant

' ═══════════════════════════════════════════
'  CAMADA 3 — SERVIÇOS
' ═══════════════════════════════════════════
node "Camada de Serviços  (Lógica de Negócio)" as SVC_Layer {
  component [ServicoAuth] as SvcAuth
  component [ServicoMoeda] as SvcMoeda
  component [ServicoVantagem] as SvcVantagem
  component [ServicoNotificacao] as SvcNotif
}

' ── Interface: ServicoNotificacao fornece, outros Servicos requerem ──
() "IServicoNotificacao" as ISvcNotif

' ── Interfaces: Repositórios fornecem, Serviços requerem ──
() "IRepositorioAluno" as IRepAl
() "IRepositorioProfessor" as IRepPr
() "IRepositorioTransferencia" as IRepTr
() "IRepositorioVantagem" as IRepVa
() "IRepositorioResgate" as IRepRe

' ═══════════════════════════════════════════
'  CAMADA 4 — REPOSITÓRIOS
' ═══════════════════════════════════════════
node "Camada de Repositórios  (Acesso a Dados)" as REPO_Layer {
  component [RepositorioAluno] as RAl
  component [RepositorioProfessor] as RPr
  component [RepositorioTransferencia] as RTr
  component [RepositorioVantagem] as RVa
  component [RepositorioResgate] as RRe
}

' ── Interface: AdaptadorEmail fornece, ServicoNotificacao requer ──
() "IAdaptadorEmail" as IEmail

' ═══════════════════════════════════════════
'  SERVIÇOS EXTERNOS
' ═══════════════════════════════════════════
node "Serviços Externos" as Ext {
  database "PostgreSQL" as DB
  component [AdaptadorEmail\n(NodeMailer)] as Email
  cloud "Servidor SMTP" as SMTP

  Email --> SMTP
}

' ═══════════════════════════════════════════
'  INTERFACES FORNECIDAS ( -- ) E REQUERIDAS ( -( )
'  Fornecida = lollipop  |  Requerida = socket (C)
' ═══════════════════════════════════════════

' ── Fronteira 1: Frontend ↔ HTTP ──
HTTP_Layer -- IRestAPI
HTTPCliente -( IRestAPI

' ── Fronteira 2: Controladores ↔ Serviços ──
SvcAuth -- ISvcAuth
CAuth -( ISvcAuth

SvcMoeda -- ISvcMoeda
CAluno -( ISvcMoeda
CProf -( ISvcMoeda

SvcVantagem -- ISvcVant
CEmpresa -( ISvcVant
CVant -( ISvcVant

' ── Fronteira 3: Entre Serviços (Notificação) ──
SvcNotif -- ISvcNotif
SvcMoeda -( ISvcNotif
SvcVantagem -( ISvcNotif

' ── Fronteira 4: Serviços ↔ Repositórios ──
RAl -- IRepAl
SvcAuth -( IRepAl
SvcMoeda -( IRepAl

RPr -- IRepPr
SvcAuth -( IRepPr
SvcMoeda -( IRepPr

RTr -- IRepTr
SvcMoeda -( IRepTr

RVa -- IRepVa
SvcVantagem -( IRepVa

RRe -- IRepRe
SvcVantagem -( IRepRe

' ── Fronteira 5: ServicoNotificacao ↔ Email ──
Email -- IEmail
SvcNotif -( IEmail

' ── Repositórios → Banco de Dados ──
RAl --> DB
RPr --> DB
RTr --> DB
RVa --> DB
RRe --> DB

@enduml
